# Python
__pycache__/
*.pyc

# KiCad local / editor state and backups
*.kicad_prl
*-backups/
fp-info-cache
*.lck
*.bak
*~

# Routing intermediates (regenerated by route.py: build -> DSN -> Freerouting -> SES)
*.dsn
*.ses

# Reports (regenerated by kicad-cli)
*-drc.rpt
*-erc.rpt

# SPICE sim artifacts (regenerated by sim/gen_deck.py and sim/run.ps1)
sim/p48.cir
sim/out.log

# Render scratch (composited outputs land in images/, raw frames are temporary)
images/_raw/

# Local-only reference material (not ours to redistribute)
fit_test/*.jpg

# Third-party reference models - not ours to redistribute
reference/
